#: data/dev.mysh.valapad.desktop.in:6 data/dev.mysh.valapad.metainfo.xml.in:7
msgid "ValaPad"
msgstr "ValaPad"

#: data/dev.mysh.valapad.desktop.in:7
msgid "Edit plain-text files"
msgstr "Редактируйте обычные текстовые файлы"

#: data/dev.mysh.valapad.desktop.in:9
msgid "valapad;text;editor;plain;"
msgstr "блокнот;текст;редактор;простой;"

#: data/dev.mysh.valapad.desktop.in:20
msgid "New Window"
msgstr "Новое окно"

#: data/dev.mysh.valapad.metainfo.xml.in:8
msgid "Edit plain-text files with a familiar set of tools"
msgstr "Редактируйте обычные текстовые файлы с помощью знакомых инструментов"

#: data/dev.mysh.valapad.metainfo.xml.in:10
msgid "Iaroslav Angliuster"
msgstr ""

#: data/dev.mysh.valapad.metainfo.xml.in:13
msgid ""
"ValaPad is a lightweight plain-text editor with a familiar menu bar and a "
"live status bar showing line and column, zoom level, line-ending style, and "
"encoding."
msgstr ""
"ValaPad — лёгкий редактор обычного текста со знакомой строкой меню и строкой "
"состояния, показывающей строку и столбец, масштаб, стиль окончания строк и "
"кодировку."

#: data/dev.mysh.valapad.metainfo.xml.in:18
msgid ""
"Find and replace text, jump to a line, choose line wrapping, and work with "
"UTF-8 files using either LF or CRLF line endings."
msgstr ""
"Ищите и заменяйте текст, переходите к нужной строке, выбирайте перенос строк "
"и работайте с файлами UTF-8 с окончаниями строк LF или CRLF."

#: data/dev.mysh.valapad.metainfo.xml.in:31
msgid "Initial release."
msgstr "Первый выпуск."
