[Desktop Entry]
Version=1.0
Type=Application

Name=ValaPad
Comment=Edit plain-text files
Categories=Utility;TextEditor;
Keywords=valapad;text;editor;plain;

Icon=com.github.hugmouse.valapad
Exec=com.github.hugmouse.valapad %F
Terminal=false
StartupNotify=true
StartupWMClass=com.github.hugmouse.valapad
MimeType=text/plain;
Actions=NewWindow;

[Desktop Action NewWindow]
Name=New Window
Exec=com.github.hugmouse.valapad
